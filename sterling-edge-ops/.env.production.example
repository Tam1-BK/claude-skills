# ─────────────────────────────────────────────────────────────────
# Sterling Edge Operations OS — Production Environment Variables
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env.local for local dev, or paste each key
# into your Vercel / Railway / Render dashboard.
# Never commit .env or .env.local to git.
# ─────────────────────────────────────────────────────────────────

# ── Database (required) ──────────────────────────────────────────
#
# Neon (recommended):
#   From neon.tech dashboard → your project → Connection Details
#   Select "Prisma" as the connection type and copy the URL.
DATABASE_URL="postgresql://user:password@ep-xxx-yyy.us-east-2.aws.neon.tech/neondb?sslmode=require"
#
# Supabase alternative:
#   From supabase.com → your project → Settings → Database
# DATABASE_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres"

# ── NextAuth (required) ──────────────────────────────────────────
#
# Generate a secret:  openssl rand -base64 32
# On Windows:         node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="replace-with-32-random-bytes-base64-encoded"
#
# Set to your Vercel deployment URL (no trailing slash).
NEXTAUTH_URL="https://your-project.vercel.app"

# ── Upstash Redis — rate limiting (strongly recommended) ─────────
#
# Provides distributed rate limiting across all serverless instances.
# Without this, rate limiting is in-memory and per-instance only.
#
# Setup:
#   1. Go to console.upstash.com → create a Redis database
#   2. Copy the REST URL and token from the database details page
#
UPSTASH_REDIS_REST_URL="https://your-db.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ── Security checklist before go-live ────────────────────────────
#
# 1. ROTATE SEED PASSWORDS: The seed data uses default passwords
#    (Admin@2024, User@2024). Change all user passwords immediately
#    after first login, or update prisma/seed.ts before seeding.
#
# 2. NODE_ENV is set automatically by Vercel to "production".
#    Do not set it manually unless you have a specific reason.
#
# 3. Confirm NEXTAUTH_URL exactly matches your public URL —
#    NextAuth will reject callbacks from other origins.
