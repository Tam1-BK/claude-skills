# Copy this file to .env and fill in ALL values before running docker compose up
# Run: cp .env.docker .env

# ── Required: generate with: openssl rand -base64 32 ──────────────────────────
NEXTAUTH_SECRET=

# ── Required: set to the URL where the app will be accessed ───────────────────
NEXTAUTH_URL=http://localhost:3000

# ── Required: choose a strong random password for the database ────────────────
# Use: openssl rand -hex 16
DB_PASSWORD=

# ── Optional overrides ────────────────────────────────────────────────────────
# DB_USER=sterling
# DB_NAME=sterling_edge_ops
# PORT=3000
