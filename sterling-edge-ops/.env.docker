# Copy this file to .env and fill in real values before deploying
# Run: cp .env.docker .env

# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-run-openssl-rand-base64-32

# Set to your public URL in production
NEXTAUTH_URL=http://localhost:3000

# Port to expose on host
PORT=3000

# Database credentials (must match docker-compose.yml)
# DB_USER=sterling
# DB_PASSWORD=sterling_secure_2024
# DB_NAME=sterling_edge_ops
